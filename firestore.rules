rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 로그인 여부 확인 헬퍼 ──────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    // ── 관리자 여부 확인 헬퍼 ─────────────────────────────
    function isAdmin() {
      return isLoggedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── 내 문서인지 확인 헬퍼 ─────────────────────────────
    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // ── 사용자 프로필 ──────────────────────────────────────
    match /users/{uid} {
      allow read:   if isLoggedIn();
      allow create: if isOwner(uid);           // 본인만 생성
      allow update: if isOwner(uid) || isAdmin(); // 본인 또는 관리자 수정
      allow delete: if isAdmin();
    }

    // ── 출석 세션 ──────────────────────────────────────────
    match /sessions/{sid} {
      allow read:   if isLoggedIn();
      allow write:  if isAdmin();              // 관리자만 세션 생성/수정/삭제
    }

    // ── 출석 기록 ──────────────────────────────────────────
    match /attendances/{aid} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();           // 회원은 출석 기록 생성 가능
      allow update,
            delete: if isAdmin();             // 수정/삭제는 관리자만
    }

    // ── 공지사항 ───────────────────────────────────────────
    match /notices/{nid} {
      allow read:   if isLoggedIn();
      allow write:  if isAdmin();              // 관리자만 작성/수정/삭제
    }

    // ── 자유게시판 ─────────────────────────────────────────
    match /freeboard/{fid} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ── 기도제목 ───────────────────────────────────────────
    match /prayers/{pid} {
      // 공개 기도제목은 로그인한 모두가 읽을 수 있음
      // 비공개는 본인과 관리자만
      allow read: if isLoggedIn() && (
        resource.data.isPublic == true ||
        isOwner(resource.data.userId) ||
        isAdmin()
      );
      allow create: if isLoggedIn();
      allow update,
            delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
